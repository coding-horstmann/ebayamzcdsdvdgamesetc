# === Railway Postgres ===
# Wird in Railway automatisch aus dem Postgres-Service referenziert.
DATABASE_URL=

# === eBay Browse API (OAuth2 Client Credentials) ===
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_API_DELAY_MS=1100
EBAY_DAILY_CALL_RESERVE=200
EBAY_SEARCH_RESULT_LIMIT=50

# === Keepa API ===
KEEPA_API_KEY=

# === Worker-Tuning ===
# Mindest-Amazonpreis in EUR. Der Worker nimmt den niedrigeren gueltigen Preis aus USED/NEW.
MIN_AMZ_PRICE=20.00
# Die besten BSR je Kategorie. Default: jeweils 15000.
KEEPA_BSR_TARGET_PER_CATEGORY=15000
# BSR-Rangbreite pro Keepa-Block.
KEEPA_BSR_WINDOW=3000
# Fallback, wenn die eBay Analytics API kein Tagesbudget liefern kann.
EBAY_FALLBACK_SCAN_LIMIT=1000
# Wenn true, fuellt alter Backlog freie eBay-Slots nach frischen Keepa-Kandidaten.
EBAY_BACKLOG_FILL=true

# === Keepa Kategorie-IDs Amazon.de ===
KEEPA_BOARD_GAME_CATEGORY_ID=360472031
KEEPA_CD_CATEGORY_ID=255882
KEEPA_DVD_CATEGORY_ID=284266
KEEPA_GAME_CATEGORY_ID=300992
KEEPA_FIGURE_CATEGORY_ID=27087992031

# === Frontend Login (optional) ===
# Wenn MEDIASCOUT_PASSWORD gesetzt ist, verlangt das Frontend eine Passwortanmeldung.
MEDIASCOUT_PASSWORD=
